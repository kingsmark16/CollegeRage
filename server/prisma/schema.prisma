// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id               String    @id @default(uuid())
  type             MediaType
  description      String?
  originalFilename String
  sanitizedName    String
  mimeType         String
  extension        String
  sizeBytes        Int
  width            Int?
  height           Int?
  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  image            Image?
  video            Video?

  @@index([type])
  @@index([uploadedByUserId])
  @@index([createdAt])
}

model Image {
  id          String   @id @default(uuid())
  mediaId     String   @unique
  dropboxPath String   @unique
  url         String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

model Video {
  id        String         @id @default(uuid())
  mediaId   String         @unique
  duration  Float?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  media     Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  variants  VideoVariant[]
  thumbnail Thumbnail?
}

model VideoVariant {
  id          String              @id @default(uuid())
  videoId     String
  quality     VideoVariantQuality
  width       Int
  height      Int
  sizeBytes   Int
  dropboxPath String              @unique
  url         String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  video       Video               @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, quality])
  @@index([quality])
}

model Thumbnail {
  id          String   @id @default(uuid())
  videoId     String   @unique
  width       Int?
  height      Int?
  sizeBytes   Int
  dropboxPath String   @unique
  url         String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model MusicTrack {
  id               String   @id @default(uuid())
  title            String
  artist           String?
  originalFilename String
  sanitizedName    String
  mimeType         String
  extension        String
  sizeBytes        Int
  duration         Float?
  dropboxPath      String   @unique
  url              String   @unique
  isActive         Boolean  @default(true)
  isDefault        Boolean  @default(false)
  uploadedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([isDefault])
  @@index([uploadedByUserId])
  @@index([createdAt])
}

model DropboxCredential {
  id                String    @id @default(uuid())
  accountId         String?   @unique
  accessToken       String
  refreshToken      String?
  tokenType         String?
  scope             String?
  expiresAt         DateTime?
  connectedByUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([connectedByUserId])
}

model DropboxOAuthState {
  state     String    @id
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AnalyticsVisitor {
  id          String                  @id @default(uuid())
  visitorKey  String                  @unique
  firstSeenAt DateTime                @default(now())
  lastSeenAt  DateTime                @default(now())
  sessions    AnalyticsVisitSession[]
  pageViews   AnalyticsPageView[]

  @@index([lastSeenAt])
}

model AnalyticsVisitSession {
  id              String              @id @default(uuid())
  sessionKey      String              @unique
  visitorId       String
  userId          String?
  userEmail       String?
  isAuthenticated Boolean             @default(false)
  ipHash          String?
  userAgent       String?
  startedAt       DateTime            @default(now())
  lastSeenAt      DateTime            @default(now())
  visitor         AnalyticsVisitor    @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageViews       AnalyticsPageView[]

  @@index([visitorId])
  @@index([userId])
  @@index([startedAt])
  @@index([lastSeenAt])
}

model AnalyticsPageView {
  id             String                @id @default(uuid())
  visitorId      String
  sessionId      String
  userId         String?
  userEmail      String?
  path           String
  title          String?
  referrer       String?
  userAgent      String?
  ipHash         String?
  viewportWidth  Int?
  viewportHeight Int?
  occurredAt     DateTime              @default(now())
  visitor        AnalyticsVisitor      @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  session        AnalyticsVisitSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([visitorId])
  @@index([sessionId])
  @@index([userId])
  @@index([path])
  @@index([occurredAt])
}

enum MediaType {
  IMAGE
  VIDEO
}

enum VideoVariantQuality {
  P480
  P720
  P1080
}

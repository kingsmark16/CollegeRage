# Copy this file to .env and provide real values locally or through your deployment platform.

NODE_ENV=production
PORT=3000
CLIENT_ORIGIN=http://localhost
VITE_API_BASE_URL=/api/v1

DATABASE_URL=postgresql://user:password@host/database?sslmode=require
NEON_AUTH_BASE_URL=
ADMIN_EMAILS=
ARCJET_KEY=

DROPBOX_REDIRECT_URI=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_TOKEN_ENCRYPTION_KEY=
DROPBOX_UPLOAD_ROOT=/uploads
DROPBOX_UPLOAD_CONCURRENCY=2

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MEDIA_TEMP_DIR=/tmp/college-rage-media
MEDIA_VIDEO_CONCURRENCY=1
DROPBOX_UPLOAD_RETRIES=3

ANALYTICS_COOKIE_NAME=cr_visitor_id
ANALYTICS_SESSION_COOKIE_NAME=cr_session_id
ANALYTICS_SESSION_TTL_MINUTES=30
ANALYTICS_IP_SALT=
